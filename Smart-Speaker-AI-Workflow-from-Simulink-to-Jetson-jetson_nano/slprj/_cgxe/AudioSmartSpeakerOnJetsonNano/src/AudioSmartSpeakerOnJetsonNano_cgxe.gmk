#--------------------------- Tool Specifications -------------------------
#
# Modify the following macros to reflect the tools you wish to use for
# compiling and linking your code.
#
CC = "C:\Program Files\MATLAB\R2026a\bin\win64\mex.exe" -R2018a
LD = $(CC)
 
MODEL     = AudioSmartSpeakerOnJetsonNano
TARGET      = cgxe
MODULE_SRCS   = m_KDwX9EsWGnc16Iuc3hY4E.c
MODEL_SRC  = AudioSmartSpeakerOnJetsonNano_cgxe.c
MODEL_REG = AudioSmartSpeakerOnJetsonNano_cgxe_registry.c
MAKEFILE    = AudioSmartSpeakerOnJetsonNano_cgxe.gmk
MATLAB_ROOT  = c:\program files\matlab\r2026a\toolbox\stateflow\stateflow\..\..\..
BUILDARGS   = 
#------------------------------ Include/Lib Path ------------------------------
 
USER_INCLUDES = -I"C:\Users\KoayXianCong\Documents\MATLAB\Examples\R2026a\deeplearning_shared\AudioSmartSpeakerOnRaspberryPiSimulinkExample" -I"C:\Users\KoayXianCong\Documents\MATLAB\Examples\R2026a\deeplearning_shared\AudioSmartSpeakerOnRaspberryPiSimulinkExample\slprj\_cprj" 
AUX_INCLUDES = 
MLSLSF_INCLUDES  = \
    -I"C:\Program Files\MATLAB\R2026a\extern\include" \
    -I"C:\Program Files\MATLAB\R2026a\simulink\include" \
    -I"C:\Program Files\MATLAB\R2026a\rtw\c\src" 

THIRD_PARTY_INCLUDES = -I"C:\Users\KoayXianCong\Documents\MATLAB\Examples\R2026a\deeplearning_shared\AudioSmartSpeakerOnRaspberryPiSimulinkExample\slprj\_cgxe\AudioSmartSpeakerOnJetsonNano\src" -I"C:\Program Files\MATLAB\R2026a\toolbox\dsp\halidesim\include" -I"C:\Program Files\MATLAB\R2026a\toolbox\dsp\include" 

INCLUDE_PATH = $(USER_INCLUDES) $(AUX_INCLUDES) $(MLSLSF_INCLUDES) $(COMPILER_INCLUDES) $(THIRD_PARTY_INCLUDES)
 
#----------------- Compiler and Linker Options --------------------------------
 
# Optimization Options
 
CC_OPTS =  -w -Wno-error=incompatible-pointer-types -O2   
CPP_REQ_DEFINES = -DMATLAB_MEX_FILE
 
# Uncomment this line to move warning level to W4
# cflags = $(cflags:W3=W4)
CFLAGS = $(CPP_REQ_DEFINES) $(INCLUDE_PATH) CFLAGS="$$CFLAGS $(CC_OPTS)"
 
LDFLAGS =   "C:\PROGRA~1\MATLAB\R2026a\bin\win64\libmwdsp_halidesim.dll"
 
AUXLDFLAGS = 
#----------------------------- Source Files -----------------------------------
 
THIRD_PARTY_SRCS =   
REQ_SRCS  = $(MODEL_SRC) $(MODEL_REG) $(MODULE_SRCS) $(THIRD_PARTY_SRCS) 

USER_OBJS =

AUX_ABS_OBJS =

REQ_OBJS = $(REQ_SRCS:.cpp=.obj)
REQ_OBJS2 = $(REQ_OBJS:.c=.obj)
OBJS = $(REQ_OBJS2) $(USER_OBJS) $(AUX_ABS_OBJS) $(THIRD_PARTY_OBJS)
OBJLIST_FILE = AudioSmartSpeakerOnJetsonNano_cgxe.mol
SFCLIB = 
AUX_LNK_OBJS = 
USER_LIBS = 
PARLIB = 
 
#--------------------------------- Rules --------------------------------------
 
MEX_FILE_NAME = $(MODEL)_$(TARGET).mexw64
 
 $(MEX_FILE_NAME): $(MAKEFILE) $(OBJS) $(SFCLIB) $(AUX_LNK_OBJS)
	@echo ### Linking ...
	$(LD) -silent LD="$$MINGWROOT\bin\g++" LDFLAGS="$$LDFLAGS $(LDFLAGS) $(AUXLDFLAGS)" -output $(MEX_FILE_NAME) @$(OBJLIST_FILE) $(USER_LIBS) $(SFCLIB) $(PARLIB) $(IPPLIB) $(THIRD_PARTY_LIBS) 
%.obj :    %.c
	$(CC) -c $(CFLAGS) $<

%.obj :    %.cpp
	$(CC) -c $(CFLAGS) $<

